# dustynv/l4t-pytorch:r35.4.1 is already pulled locally on the Jetson (no re-download).
# It ships PyTorch compiled with CUDA 11.4 for ARM64, matching JetPack 5.1.x.
FROM dustynv/l4t-pytorch:r35.4.1

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# torch + torchvision already bundled in base image (CUDA 11.4, ARM64)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3-pip \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender-dev \
        ffmpeg \
        gstreamer1.0-tools \
        gstreamer1.0-plugins-base \
        gstreamer1.0-plugins-good \
        gstreamer1.0-plugins-bad \
        gstreamer1.0-plugins-ugly \
        gstreamer1.0-libav \
        libgstreamer1.0-dev \
        libgstreamer-plugins-base1.0-dev \
        python3-gst-1.0 \
        curl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .

RUN pip3 install -r requirements.txt && \
    # Remove any pip opencv pulled in by cvzone/ultralytics, then install a clean
    # headless build to avoid the system cv2 circular import bug on Jetson.
    pip3 uninstall -y opencv-python opencv-contrib-python 2>/dev/null || true && \
    rm -rf /usr/local/lib/python3.8/dist-packages/cv2 2>/dev/null || true && \
    pip3 install "opencv-python-headless==4.8.1.78"

COPY main.py yolo11n.pt ./

EXPOSE 8080

CMD ["python3", "main.py"]
